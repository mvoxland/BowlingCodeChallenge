@using BowlingLogic

<div class="scorecard-container">
    <table class="scorecard">
        <tr class="frame-header-row">
            @if (showNames)
            {
                <th class="player-header"></th>
            }
            @for (int i = 0; i < maxFrames; i++)
            {
                var frameIndex = i;
                <th class="frame-header @(frameIndex == maxFrames - 1 ? "last-frame" : "")">
                    @(frameIndex + 1)
                </th>
            }
        </tr>

        @for (int p = 0; p < Players.Count; p++)
        {
            var playerIndex = p;
            var player = Players[playerIndex];
            var card = player.ScoreCard;
            bool isActive = playerIndex == ActivePlayerIndex;
            bool highlightCurrentFrame = ActivePlayerIndex is null || isActive;

            <tr class="rolls-row @(isActive ? "active-player" : "")">
                @if (showNames)
                {
                    <td class="player-name-cell" rowspan="2">@player.Name</td>
                }
                @for (int i = 0; i < card.TotalFrames; i++)
                {
                    var frameIndex = i;
                    bool isLast = frameIndex == card.TotalFrames - 1;
                    bool isCurrent = highlightCurrentFrame && frameIndex == card.GetCurrentFrameIndex();
                    <td class="roll-cell @(isCurrent ? "current-frame" : "") @(isLast ? "last-frame" : "")">
                        <div class="roll-boxes">
                            <span class="roll-box @GetRollClass(card, frameIndex, 0)">@GetRollDisplay(card, frameIndex, 0)</span>
                            <span class="roll-box @GetRollClass(card, frameIndex, 1)">@GetRollDisplay(card, frameIndex, 1)</span>
                            @if (isLast)
                            {
                                <span class="roll-box @GetRollClass(card, frameIndex, 2)">@GetRollDisplay(card, frameIndex, 2)</span>
                            }
                        </div>
                    </td>
                }
            </tr>
            <tr class="score-row @(isActive ? "active-player" : "")">
                @for (int i = 0; i < card.TotalFrames; i++)
                {
                    var frameIndex = i;
                    bool isLast = frameIndex == card.TotalFrames - 1;
                    bool isCurrent = highlightCurrentFrame && frameIndex == card.GetCurrentFrameIndex();
                    <td class="score-cell @(isCurrent ? "current-frame" : "") @(isLast ? "last-frame" : "")">
                        @GetCumulativeScore(card, frameIndex)
                    </td>
                }
            </tr>
        }
    </table>
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<PlayerScoreCard> Players { get; set; } = [];

    [Parameter]
    public int? ActivePlayerIndex { get; set; }

    bool showNames => Players.Count > 1;

    int maxFrames => Players.Any() ? Players.Max(p => p.ScoreCard.TotalFrames) : 0;

    private static string GetCumulativeScore(ScoreCard card, int frameIndex)
    {
        var frame = card.Frames[frameIndex];
        var score = card.GetScore(frame);
        return score?.ToString() ?? "";
    }

    /// <summary>
    /// Returns the text to display for a given roll in a frame.
    /// </summary>
    private static string GetRollDisplay(ScoreCard card, int frameIndex, int rollIndex)
    {
        var frame = card.Frames[frameIndex];

        if (rollIndex >= frame.Rolls.Count)
            return "";

        int rolled = frame.Rolls[rollIndex];

        if (rolled == frame.PinCount)
        {
            return "X";
        }
        else if (rollIndex == 1 && frame.Rolls[0] + rolled == frame.PinCount)
        {
            return "/";
        }
        else if (rolled == 0)
        {
            return "-";
        }
        else
        {
            return rolled.ToString();
        }
    }

    /// <summary>
    /// Returns a CSS class for special roll symbols (strike/spare) to allow distinct styling.
    /// </summary>
    private static string GetRollClass(ScoreCard card, int frameIndex, int rollIndex)
    {
        var display = GetRollDisplay(card, frameIndex, rollIndex);
        return display switch
        {
            "X" => "strike",
            "/" => "spare",
            _ => ""
        };
    }
}
