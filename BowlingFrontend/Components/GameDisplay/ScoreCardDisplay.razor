@using BowlingLogic

<div class="scorecard-container">
    <table class="scorecard">
        <tr class="frame-header-row">
            @for (int i = 0; i < ScoreCard.TotalFrames; i++)
            {
                var frameIndex = i;
                bool isLast = frameIndex == ScoreCard.TotalFrames - 1;
                bool isCurrent = frameIndex == ScoreCard.GetCurrentFrameIndex();
                <th class="frame-header @(isCurrent ? "current-frame" : "") @(isLast ? "last-frame" : "")">
                    @(frameIndex + 1)
                </th>
            }
        </tr>
        <tr class="rolls-row">
            @for (int i = 0; i < ScoreCard.TotalFrames; i++)
            {
                var frameIndex = i;
                bool isLast = frameIndex == ScoreCard.TotalFrames - 1;
                bool isCurrent = frameIndex == ScoreCard.GetCurrentFrameIndex();
                <td class="roll-cell @(isCurrent ? "current-frame" : "") @(isLast ? "last-frame" : "")">
                    <div class="roll-boxes">
                        <span class="roll-box @GetRollClass(frameIndex, 0)">@GetRollDisplay(frameIndex, 0)</span>
                        <span class="roll-box @GetRollClass(frameIndex, 1)">@GetRollDisplay(frameIndex, 1)</span>
                        @if (isLast)
                        {
                            <span class="roll-box @GetRollClass(frameIndex, 2)">@GetRollDisplay(frameIndex, 2)</span>
                        }
                    </div>
                </td>
            }
        </tr>
        <tr class="score-row">
            @for (int i = 0; i < ScoreCard.TotalFrames; i++)
            {
                var frameIndex = i;
                bool isLast = frameIndex == ScoreCard.TotalFrames - 1;
                bool isCurrent = frameIndex == ScoreCard.GetCurrentFrameIndex();
                <td class="score-cell @(isCurrent ? "current-frame" : "") @(isLast ? "last-frame" : "")">
                    @GetCumulativeScore(frameIndex)
                </td>
            }
        </tr>
    </table>
</div>

@code {
    [Parameter, EditorRequired]
    public ScoreCard ScoreCard { get; set; }

    public EventCallback<int> Rolled { get; set; }

    private string GetCumulativeScore(int frameIndex)
    {
        var frame = ScoreCard.Frames[frameIndex];
        var score = ScoreCard.GetScore(frame);
        return score?.ToString() ?? "";
    }

    /// <summary>
    /// Returns the text to display for a given roll in a frame.
    /// </summary>
    private string GetRollDisplay(int frameIndex, int rollIndex)
    {
        var frame = ScoreCard.Frames[frameIndex];

        if (rollIndex >= frame.Rolls.Count)
            return "";

        int rolled = frame.Rolls[rollIndex];

        if (rolled == frame.PinCount)
        {
            return "X";
        }
        else if (rollIndex == 1 && frame.Rolls[0] + rolled == frame.PinCount)
        {
            return "/";
        }
        else if (rolled == 0)
        {
            return "-";
        }
        else
        {
            return rolled.ToString();
        }
    }

    /// <summary>
    /// Returns a CSS class for special roll symbols (strike/spare) to allow distinct styling.
    /// </summary>
    private string GetRollClass(int frameIndex, int rollIndex)
    {
        var display = GetRollDisplay(frameIndex, rollIndex);
        return display switch
        {
            "X" => "strike",
            "/" => "spare",
            _ => ""
        };
    }
}
